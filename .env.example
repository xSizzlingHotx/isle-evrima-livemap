# ============================================================
# Discord OAuth — https://discord.com/developers/applications
# ============================================================
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# ============================================================
# NextAuth
# ============================================================
NEXTAUTH_SECRET=change_this_to_any_random_32_char_string
NEXTAUTH_URL=https://your-domain.com

# ============================================================
# MySQL Database (your own DB — any source works)
# ============================================================
DB_HOST=your_db_host
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# ============================================================
# Optional: PrimalCore mode
# Set to true if you want to use PrimalCore's existing tables
# (idsync + playerstats) instead of creating your own.
# ============================================================
# USE_PRIMALCORE=true