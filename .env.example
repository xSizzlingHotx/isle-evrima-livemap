# PrimalCore MySQL Database
PRIMALCORE_DB_HOST=your_db_host_ip
PRIMALCORE_DB_USER=root
PRIMALCORE_DB_PASSWORD=your_db_password
PRIMALCORE_DB_NAME=primalcore